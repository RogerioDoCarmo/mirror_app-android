{
  "name": "mirror-app",
  "version": "1.3.1",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "run:android": "expo run:android --device",
    "run:ios": "expo run:ios --device",
    "build:apk": "eas build --platform android --profile preview",
    "build:ipa": "eas build --platform ios --profile production",
    "build:aab": "eas build --platform android --profile production",
    "build:aab:local": "eas build --platform android --profile production --local",
    "build:apk:local": "eas build --platform android --profile preview --local",
    "build:ipa:local": "eas build --platform ios --profile production --local",
    "test:e2e": "maestro test .maestro/flows/",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --coverage --ci --forceExit",
    "mutation": "stryker run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "storybook": "EXPO_PUBLIC_STORYBOOK_ENABLED=true expo start --clear",
    "storybook:web": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "chromatic --exit-zero-on-changes"
  },
  "dependencies": {
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/slider": "5.0.1",
    "expo": "~54.0.35",
    "expo-camera": "~17.0.10",
    "expo-dev-client": "~6.0.21",
    "expo-localization": "^17.0.9",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "^2.28.0",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@storybook/addon-ondevice-actions": "^10.4.7",
    "@storybook/addon-ondevice-backgrounds": "^10.4.7",
    "@storybook/addon-ondevice-controls": "^10.4.7",
    "@storybook/addon-ondevice-notes": "^10.4.7",
    "@storybook/react-native": "^10.4.7",
    "@storybook/react-native-web-vite": "^10.4.6",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/jest-runner": "^9.6.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "chromatic": "^17.7.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.3",
    "eslint-plugin-jsdoc": "^63.0.10",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-testing-library": "^7.16.2",
    "fast-check": "^4.8.0",
    "husky": "^9.1.7",
    "jest-expo": "^54.0.17",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.1",
    "react-test-renderer": "19.1.0",
    "storybook": "^10.4.6",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.3"
  },
  "private": true,
  "pnpm": {
    "overrides": {
      "postcss": ">=8.5.10",
      "qs": ">=6.15.2",
      "uuid": ">=11.1.1",
      "esbuild": ">=0.28.1",
      "shell-quote": ">=1.8.4",
      "undici": ">=6.27.0 <7.0.0",
      "ws": ">=6.2.4",
      "tar": ">=7.5.16",
      "form-data": ">=4.0.6"
    }
  },
  "expo": {
    "autolinking": {
      "android": {
        "buildFromSource": [
          ".*"
        ]
      }
    }
  }
}
